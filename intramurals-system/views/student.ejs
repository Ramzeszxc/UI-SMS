<!DOCTYPE html>
<html lang="en">
<head>
    <title>Student Portal | LPU Golazo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }</style>
</head>
<body>
    <nav class="navbar navbar-dark p-3 shadow-sm" style="background-color: #002147;">
        <div class="container">
            <span class="navbar-brand fw-bold">🏛️ LPU Golazo Student Portal</span>
            <div>
                <button class="btn fw-bold me-3" style="background-color: #FFB81C; color: #002147;" data-bs-toggle="modal" data-bs-target="#qrModal">📱 Show Digital Pass</button>
                <a href="/logout" class="btn btn-outline-light">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center" style="background-color: #e9f2fa; color: #002147;">
            <span class="fs-4 me-3">📢</span>
            <div><strong>LPU Announcement:</strong> <%= announcement %></div>
        </div>

        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white fw-bold pt-3 border-0">Team Application</div>
                    <div class="card-body">
                        <% if (!myTeam) { %>
                        <form action="/student/apply-team" method="POST">
                            <input type="text" name="teamId" class="form-control mb-2 bg-light border-0" placeholder="Desired Team ID" required>
                            <input type="text" name="name" class="form-control mb-2 bg-light border-0" placeholder="Team Name" required>
                            <textarea name="players" class="form-control mb-3 bg-light border-0" placeholder="Roster..." rows="3" required></textarea>
                            <button class="btn text-white w-100 fw-bold" style="background-color: #002147;">Submit Request</button>
                        </form>
                        <% } else { %>
                            <p>Status: <span class="badge bg-<%= myTeam.status === 'Pending'?'warning':'success'%>"><%= myTeam.status %></span></p>
                            <form action="/student/edit-team" method="POST">
                                <input type="hidden" name="teamId" value="<%= myTeam.id %>">
                                <label class="form-label text-muted small">Team Name</label>
                                <input type="text" name="name" class="form-control mb-2" value="<%= myTeam.name %>" <%= myTeam.status !== 'Pending' ? 'readonly' : '' %>>
                                <label class="form-label text-muted small">Players</label>
                                <textarea name="players" class="form-control mb-3" rows="3" <%= myTeam.status !== 'Pending' ? 'readonly' : '' %>><%= myTeam.players %></textarea>
                                <% if (myTeam.status === 'Pending') { %>
                                    <button type="submit" class="btn btn-warning w-100">Update Roster</button>
                                <% } else { %>
                                    <button type="button" class="btn btn-secondary w-100" disabled>Roster Locked (Cleared)</button>
                                <% } %>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border-0 mb-4 table-responsive">
                    <div class="card-header bg-dark text-white">Live Standings</div>
                    <table class="table table-sm m-0 align-middle">
                        <thead><tr><th>Rank</th><th>Team</th><th>Score</th></tr></thead>
                        <tbody>
                            <% leaderboard.forEach((team, index) => { %> <tr><td>#<%= index + 1 %></td><td><strong><%= team.name %></strong></td><td><%= team.score %></td></tr> <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="card shadow-sm border-0 table-responsive">
                    <div class="card-header bg-primary text-white">My Active Gear Loans</div>
                    <table class="table table-sm m-0 align-middle">
                        <thead><tr><th>Item</th><th>Qty</th><th>Date Borrowed</th></tr></thead>
                        <tbody>
                            <% myLoans.forEach(loan => { %> <tr><td><%= loan.item.replace('_', ' ') %></td><td><%= loan.quantity %></td><td><small class="text-muted"><%= loan.date %></small></td></tr> <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="qrModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg text-center p-4">
                <h5 class="fw-bold" style="color: #002147;">LPU Student Pass</h5>
                <p class="text-muted small">Show this at the Equipment Desk</p>
                <div class="bg-light p-3 rounded-3 mx-auto">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=LPU-<%= username %>" class="img-fluid" alt="QR Pass">
                </div>
                <h6 class="mt-3 text-muted" style="word-break: break-all;"><%= username %></h6>
                <button type="button" class="btn btn-outline-secondary mt-3" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('error')) Swal.fire({ icon: 'error', title: 'Oops...', text: urlParams.get('error') });
        if (urlParams.has('success')) Swal.fire({ icon: 'success', title: 'Success!', text: urlParams.get('success'), timer: 2000, showConfirmButton: false });
        window.history.replaceState({}, document.title, window.location.pathname);
    </script>
</body>
</html>