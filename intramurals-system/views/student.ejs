<!DOCTYPE html>
<html lang="en">
<head>
    <title>Student Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between mb-4">
            <h1>Welcome, <%= username %>! 👋</h1>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>

        <div class="row">
            <!-- Apply for Team -->
            <div class="col-md-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">Apply for Intramurals</div>
                    <div class="card-body">
                        <form action="/student/apply-team" method="POST">
                            <input type="text" name="teamId" class="form-control mb-2" placeholder="Desired Team ID (e.g. 102)" required>
                            <input type="text" name="name" class="form-control mb-2" placeholder="Team Name" required>
                            <label class="form-label text-muted small mt-2">Specific Player Names (Comma separated)</label>
                            <textarea name="players" class="form-control mb-3" rows="3" placeholder="John Doe, Jane Smith..." required></textarea>
                            <button type="submit" class="btn btn-success w-100">Submit Team Application</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <!-- Standings -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">Current Standings</div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead><tr><th>Rank</th><th>Team</th><th>Score</th></tr></thead>
                            <tbody>
                                <% leaderboard.forEach((team, index) => { %>
                                    <tr><td>#<%= index + 1 %></td><td><%= team.name %></td><td><%= team.score %></td></tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- My Active Loans -->
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">My Borrowed Equipment</div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead><tr><th>Item</th><th>Qty</th><th>Date Borrowed</th></tr></thead>
                            <tbody>
                                <% myLoans.forEach(loan => { %>
                                    <tr>
                                        <td><%= loan.item.replace('_', ' ') %></td>
                                        <td><%= loan.quantity %></td>
                                        <td><%= loan.date %></td>
                                    </tr>
                                <% }) %>
                                <% if (myLoans.length === 0) { %>
                                    <tr><td colspan="3" class="text-muted text-center">You have no active loans.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>