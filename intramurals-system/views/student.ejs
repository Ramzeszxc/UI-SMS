<!DOCTYPE html>
<html lang="en">
<head>
    <title>Student Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between mb-4">
            <h1>Welcome, <%= username %>! 👋</h1>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>

        <div class="row">
            <!-- Apply / Edit Team -->
            <div class="col-md-4">
                <% if (!myTeam) { %>
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-success text-white">Apply for Intramurals</div>
                        <div class="card-body">
                            <form action="/student/apply-team" method="POST">
                                <input type="text" name="teamId" class="form-control mb-2" placeholder="Desired Team ID" required>
                                <input type="text" name="name" class="form-control mb-2" placeholder="Team Name" required>
                                <textarea name="players" class="form-control mb-3" rows="3" placeholder="Players..." required></textarea>
                                <button type="submit" class="btn btn-success w-100">Submit Application</button>
                            </form>
                        </div>
                    </div>
                <% } else { %>
                    <div class="card shadow-sm mb-4 border-<%= myTeam.status === 'Pending' ? 'warning' : 'success' %>">
                        <div class="card-header bg-<%= myTeam.status === 'Pending' ? 'warning' : 'success' %> text-white">
                            My Team Status: <%= myTeam.status %>
                        </div>
                        <div class="card-body">
                            <form action="/student/edit-team" method="POST">
                                <input type="hidden" name="teamId" value="<%= myTeam.id %>">
                                <label class="form-label text-muted small">Team Name</label>
                                <input type="text" name="name" class="form-control mb-2" value="<%= myTeam.name %>" <%= myTeam.status !== 'Pending' ? 'readonly' : '' %>>
                                <label class="form-label text-muted small">Players</label>
                                <textarea name="players" class="form-control mb-3" rows="3" <%= myTeam.status !== 'Pending' ? 'readonly' : '' %>><%= myTeam.players %></textarea>
                                
                                <% if (myTeam.status === 'Pending') { %>
                                    <button type="submit" class="btn btn-warning w-100">Update Roster</button>
                                    <small class="text-muted mt-2 d-block text-center">You can edit until a Manager clears you.</small>
                                <% } else { %>
                                    <button type="button" class="btn btn-secondary w-100" disabled>Roster Locked (Cleared)</button>
                                <% } %>
                            </form>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Tables (Responsive) -->
            <div class="col-md-8">
                <div class="card shadow-sm mb-4 table-responsive">
                    <div class="card-header bg-dark text-white">Standings</div>
                    <table class="table table-sm m-0">
                        <thead><tr><th>Rank</th><th>Team</th><th>Score</th></tr></thead>
                        <tbody>
                            <% leaderboard.forEach((team, index) => { %>
                                <tr><td>#<%= index + 1 %></td><td><%= team.name %></td><td><%= team.score %></td></tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="card shadow-sm table-responsive">
                    <div class="card-header bg-primary text-white">My Active Gear Loans</div>
                    <table class="table table-sm m-0">
                        <thead><tr><th>Item</th><th>Qty</th><th>Date</th></tr></thead>
                        <tbody>
                            <% myLoans.forEach(loan => { %>
                                <tr><td><%= loan.item.replace('_', ' ') %></td><td><%= loan.quantity %></td><td><%= loan.date %></td></tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('error')) Swal.fire({ icon: 'error', title: 'Oops...', text: urlParams.get('error') });
        if (urlParams.has('success')) Swal.fire({ icon: 'success', title: 'Success!', text: urlParams.get('success'), timer: 2000, showConfirmButton: false });
        window.history.replaceState({}, document.title, window.location.pathname);
    </script>
</body>
</html>