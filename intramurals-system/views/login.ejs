<!DOCTYPE html>
<html lang="en">
<head>
    <title>Golazo | LPU Intramurals</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; background-color: #f4f6f9; }</style>
</head>
<body class="d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="card shadow-lg border-0" style="width: 450px; border-radius: 12px; overflow: hidden;">
        <div class="bg-primary text-white text-center p-4" style="background-color: #002147 !important;">
            <h2 class="fw-bold mb-0">🏛️ Lanao Premier</h2>
            <small style="color: #FFB81C;">Golazo Intramurals Portal</small>
        </div>
        <div class="card-body p-4">
            <% if (error) { %> <div class="alert alert-danger"><%= error %></div> <% } %>
            
            <form action="/login" method="POST" class="mb-4">
                <label class="form-label text-muted small fw-bold mb-1">LPU Email / Staff ID</label>
                <input type="text" name="username" class="form-control mb-3 p-2" placeholder="e.g. student@lpu.edu.ph" required>
                <label class="form-label text-muted small fw-bold mb-1">Password</label>
                <input type="password" name="password" class="form-control mb-4 p-2" placeholder="••••••••" required>
                <button type="submit" class="btn w-100 text-white fw-bold py-2" style="background-color: #002147;">Secure Sign In</button>
            </form>
            <hr>
            
            <p class="text-center text-muted mb-2"><small>New Student Activation</small></p>
            <form action="/register" method="POST" class="d-flex gap-2">
                <input type="email" name="username" class="form-control form-control-sm" placeholder="Email (@lpu.edu.ph)" pattern=".*@lpu\.edu\.ph$" title="Must end with @lpu.edu.ph" required>
                <input type="password" name="password" class="form-control form-control-sm" placeholder="Password" required>
                <button type="submit" class="btn btn-sm btn-outline-secondary fw-bold">Activate</button>
            </form>
        </div>
    </div>
</body>
</html>