<!DOCTYPE html>
<html lang="en">
<head>
    <title>Intramurals Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <h1 class="mb-4">🏆 Futsal Tournament Dashboard</h1>
        <nav class="mb-4">
            <a href="/" class="btn btn-primary">Dashboard</a>
            <a href="/teams" class="btn btn-outline-primary">Manage Teams</a>
            <a href="/equipment" class="btn btn-outline-primary">Manage Equipment</a>
            <a href="/logout" class="btn btn-danger float-end ms-2">Logout</a>
            <a href="/backup" class="btn btn-warning float-end">📥 Download JSON Backup</a>
        </nav>

        <div class="row">
            <!-- LEADERBOARD -->
            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">Live Leaderboard</div>
                    <div class="card-body">
                        <table class="table">
                            <thead><tr><th>Rank</th><th>Team Name</th><th>Points</th><th>Action</th></tr></thead>
                            <tbody>
                                <% leaderboard.forEach((team, index) => { %>
                                    <tr>
                                        <td>#<%= index + 1 %></td>
                                        <td><strong><%= team.name %></strong></td>
                                        <td><%= team.score %></td>
                                        <td>
                                            <form action="/teams/score" method="POST" class="d-inline">
                                                <input type="hidden" name="teamId" value="<%= team.id %>">
                                                <input type="hidden" name="points" value="3">
                                                <button type="submit" class="btn btn-sm btn-success">+3 Pts (Win)</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
    </div>

<script>
    // We wrap the EJS in quotes or add a fallback to 0
    const futsalCount = Number("<%= equipment.futsalBalls %>") || 0;
    const bibsCount = Number("<%= equipment.bibs %>") || 0;

    const ctx = document.getElementById('equipmentChart').getContext('2d');
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Futsal Balls', 'Training Bibs'],
            datasets: [{
                data: [futsalCount, bibsCount], // Use the clean variables here
                backgroundColor: ['#0d6efd', '#ffc107']
            }]
        }
    });
</script>
</body>
</html>