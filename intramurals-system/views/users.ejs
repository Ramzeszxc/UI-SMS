<!DOCTYPE html>
<html lang="en">
<head>
    <title>Users | LPU Golazo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }</style>
</head>
<body class="d-flex flex-nowrap" style="min-height: 100vh;">
    <div class="d-flex flex-column p-3 text-white" style="width: 250px; background-color: #002147;">
        <span class="fs-5 fw-bold text-center mb-1">🏛️ LPU Golazo</span>
        <span class="text-center mb-4" style="color: #FFB81C; font-size: 12px;">Role: <%= role.toUpperCase() %></span>
        <ul class="nav nav-pills flex-column mb-auto gap-2">
            <li><a href="/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
            <li><a href="/teams" class="nav-link text-white">⚙️ Manage Teams</a></li>
            <li><a href="/equipment" class="nav-link text-white">⚽ Equipment Desk</a></li>
            <li><a href="/history" class="nav-link text-white">🗄️ Audit Trail</a></li>
            <li><a href="/users" class="nav-link text-white bg-secondary bg-opacity-25 fw-bold mt-3 border-top pt-3">👥 Manage Staff</a></li>
        </ul>
        <a href="/logout" class="btn btn-outline-light btn-sm mt-4">Logout</a>
    </div>

    <main class="flex-grow-1 p-5">
        <h2 class="fw-bold mb-4">👥 Manage University Staff</h2>
        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white fw-bold pt-3 border-0">Onboard New Staff</div>
                    <div class="card-body">
                        <form action="/users/create" method="POST">
                            <input type="text" name="username" class="form-control mb-3 bg-light border-0" placeholder="Staff Username (No Domain Req.)" required>
                            <select name="role" class="form-select mb-3 bg-light border-0">
                                <option value="manager">Athletics Manager</option>
                                <option value="faculty">Faculty Auditor (Read-Only)</option>
                            </select>
                            <input type="password" name="password" class="form-control mb-4 bg-light border-0" placeholder="Initial Password" required>
                            <button type="submit" class="btn text-white w-100 fw-bold" style="background-color: #002147;">Create Account</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card shadow-sm border-0 table-responsive">
                    <table class="table align-middle m-0">
                        <thead class="table-light"><tr><th>Staff Username</th><th>System Role</th></tr></thead>
                        <tbody>
                            <% staff.forEach(user => { %>
                                <tr>
                                    <td><strong><%= user.username %></strong></td>
                                    <td><span class="badge bg-<%= user.role === 'admin'?'danger':(user.role === 'manager'?'primary':'secondary') %>"><%= user.role.toUpperCase() %></span></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

<!-- Socket.io and SweetAlert Integration -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        // 1. Real-Time Socket Logic
        const socket = io();
        socket.on('live_update', (message) => {
            const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 1500, timerProgressBar: true });
            Toast.fire({ icon: 'info', title: 'Live Update', text: message }).then(() => window.location.reload());
        });

        // 2. URL Parameters Logic (SweetAlerts)
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('error')) Swal.fire({ icon: 'error', title: 'Oops...', text: urlParams.get('error') });
        if (urlParams.has('success')) Swal.fire({ icon: 'success', title: 'Success', text: urlParams.get('success'), timer: 2000, showConfirmButton: false });
        window.history.replaceState({}, document.title, window.location.pathname);
    </script>
    
</body>
</html>