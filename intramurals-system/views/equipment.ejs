<!DOCTYPE html>
<html lang="en">
<head>
    <title>Equipment Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <h1 class="mb-4">Sports Equipment Logs</h1>
        <nav class="mb-4">
            <a href="/manager/dashboard" class="btn btn-outline-primary">Back to Dashboard</a>
            <a href="/teams" class="btn btn-outline-primary">Manage Teams</a>
            <a href="/equipment/history" class="btn btn-outline-primary">History</a>
            <a href="/logout" class="btn btn-danger float-end ms-2">Logout</a>
        </nav>

        <div class="row">
            <div class="col-md-4">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">Log Borrowed Gear</div>
                    <div class="card-body">
                        <form action="/equipment/borrow" method="POST">
                        <label class="form-label">Select Student Account</label>
                            <select name="borrower" class="form-select mb-2" required>
                                <option value="" disabled selected>-- Choose a Registered Student --</option>
                                <% students.forEach(student => { %>
                                <option value="<%= student %>"><%= student %></option>
                                <% }) %>
                            </select>
    
                        <label class="form-label">Item</label>
                            <select name="item" class="form-select mb-2">
                                <option value="futsal_balls">Futsal Ball</option>
                                <option value="bibs">Training Bibs</option>
                                <option value="cones">Cones</option>
                            </select>

                        <label class="form-label">Quantity</label>
                    <input type="number" name="quantity" class="form-control mb-3" value="1" min="1" required>
    
            <button type="submit" class="btn btn-primary w-100">Confirm Borrowing</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <span>Current Active Loans</span>
                        <form action="/equipment" method="GET" class="d-flex">
                            <input type="text" name="search" class="form-control form-control-sm me-2" placeholder="Search borrower...">
                            <button class="btn btn-sm btn-light">Search</button>
                        </form>
                    </div>
                    <div class="card-body">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Borrower</th>
                                    <th>Item</th>
                                    <th>Qty</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% loans.forEach(loan => { %>
                                    <tr>
                                        <td><strong><%= loan.borrower %></strong></td>
                                        <td><%= loan.item.replace('_', ' ') %></td>
                                        <td><%= loan.quantity %></td>
                                        <td><span class="badge bg-warning text-dark">Out</span></td>
                                        <td>
                                            <form action="/equipment/return" method="POST">
                                                <input type="hidden" name="loanId" value="<%= loan.id %>">
                                                <input type="hidden" name="item" value="<%= loan.item %>">
                                                <input type="hidden" name="quantity" value="<%= loan.quantity %>">
                                                <button type="submit" class="btn btn-sm btn-outline-success">Mark Returned</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                                <% if (loans.length === 0) { %>
                                    <tr><td colspan="5" class="text-center text-muted">No equipment currently out.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>