<!DOCTYPE html>
<html lang="en">
<head>
    <title>Equipment | LPU Golazo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <style>body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }</style>
</head>
<body class="d-flex flex-nowrap" style="min-height: 100vh;">
    <div class="d-flex flex-column p-3 text-white" style="width: 250px; background-color: #002147;">
        <span class="fs-5 fw-bold text-center mb-1">🏛️ LPU Golazo</span>
        <span class="text-center mb-4" style="color: #FFB81C; font-size: 12px;">Role: <%= role.toUpperCase() %></span>
        <ul class="nav nav-pills flex-column mb-auto gap-2">
            <li><a href="/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
            <li><a href="/teams" class="nav-link text-white">⚙️ Manage Teams</a></li>
            <li><a href="/equipment" class="nav-link text-white bg-secondary bg-opacity-25 fw-bold">⚽ Equipment Desk</a></li>
            <li><a href="/history" class="nav-link text-white">🗄️ Audit Trail</a></li>
            <% if (role === 'admin') { %> <li><a href="/users" class="nav-link text-white mt-3 border-top pt-3">👥 Manage Staff</a></li> <% } %>
        </ul>
        <a href="/logout" class="btn btn-outline-light btn-sm mt-4">Logout</a>
    </div>

    <main class="flex-grow-1 p-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">⚽ Equipment Desk</h2>
            <% if (role !== 'faculty') { %>
            <button class="btn text-white fw-bold shadow-sm" style="background-color: #FFB81C; color: #002147 !important;" data-bs-toggle="modal" data-bs-target="#qrModal">
                📷 Scan Student Pass
            </button>
            <% } %>
        </div>

        <div class="row">
            <% if (role !== 'faculty') { %>
            <div class="col-md-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white fw-bold pt-3 border-0">Issue New Gear</div>
                    <div class="card-body">
                        <form action="/equipment/borrow" method="POST">
                            <label class="form-label text-muted small fw-bold">Student Account</label>
                            <select name="borrower" class="form-select mb-3 bg-light border-0" required>
                                <option value="" disabled <%= !prefillStudent ? 'selected' : '' %>>-- Select Student --</option>
                                <% students.forEach(student => { %>
                                    <option value="<%= student %>" <%= prefillStudent === student ? 'selected' : '' %>><%= student %></option>
                                <% }) %>
                            </select>
                            <label class="form-label text-muted small fw-bold">Item</label>
                            <select name="item" class="form-select mb-3 bg-light border-0"><option value="futsal_balls">Futsal Ball</option><option value="bibs">Training Bibs</option></select>
                            <label class="form-label text-muted small fw-bold">Quantity</label>
                            <input type="number" name="quantity" class="form-control mb-4 bg-light border-0" value="1" min="1" required>
                            <button type="submit" class="btn text-white w-100 fw-bold" style="background-color: #002147;">Confirm Issue</button>
                        </form>
                    </div>
                </div>
            </div>
            <% } %>

            <div class="col-md-8">
                <div class="card shadow-sm border-0 table-responsive">
                    <div class="card-body">
                        <table class="table align-middle m-0">
                            <thead class="table-light"><tr><th>Borrower</th><th>Item</th><th>Issued By</th><% if(role !== 'faculty'){%><th>Action</th><%}%></tr></thead>
                            <tbody>
                                <% loans.forEach(loan => { %>
                                    <tr>
                                        <td><strong><%= loan.borrower %></strong></td><td><%= loan.item.replace('_',' ') %> (x<%= loan.quantity %>)</td><td><small class="text-muted"><%= loan.issuedBy %></small></td>
                                        <% if (role !== 'faculty') { %>
                                        <td>
                                            <form action="/equipment/return" method="POST" class="m-0">
                                                <input type="hidden" name="loanId" value="<%= loan.id %>"><input type="hidden" name="item" value="<%= loan.item %>"><input type="hidden" name="quantity" value="<%= loan.quantity %>">
                                                <button type="submit" class="btn btn-sm btn-outline-success fw-bold">Return</button>
                                            </form>
                                        </td>
                                        <% } %>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="modal fade" id="qrModal" tabindex="-1">
        <div class="modal-dialog"><div class="modal-content border-0"><div class="modal-body"><div id="reader"></div></div></div></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: {width: 250, height: 250} }, false);
        html5QrcodeScanner.render((decodedText) => {
            html5QrcodeScanner.clear();
            const studentUsername = decodedText.split('-')[1]; // Splits "LPU-student@lpu.edu.ph"
            window.location.href = `/equipment?student=${studentUsername}`;
        });

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) Swal.fire({ icon: 'success', title: 'Success', text: urlParams.get('success'), timer: 2000, showConfirmButton: false });
        window.history.replaceState({}, document.title, window.location.pathname);
    </script>
</body>
</html>